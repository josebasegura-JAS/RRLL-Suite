{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/main",
    "rootDir": "src/main",
    "strict": true,
    "types": ["node", "electron"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.ts", "src/domain/**/*.ts"]
}
